[fs-uae]
# BFS Stress Test — local development config
# See BFStest.fs-uae.template for setup instructions.

amiga_model = A1200
chip_memory = 2048
fast_memory = 8192
cpu = 68020

# TODO: Set your local paths below
kickstart_file = ${KICKSTART_FILE}

hard_drive_0 = ${WB_DIR}
hard_drive_0_label = System
hard_drive_0_priority = 0

hard_drive_1 = ../stress.hdf

floppy_speed = 0
uae_cpu_speed = max

window_width = 800
window_height = 600
fullscreen = 0
